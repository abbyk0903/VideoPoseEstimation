{
  "name": "exercise-pose-estimation-api",
  "version": "1.0.0",
  "description": "Standalone backend for Exercise Video Pose Estimation API using MediaPipe",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "dev:watch": "nodemon --exec ts-node src/server.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "pose-estimation",
    "mediapipe",
    "video-analysis",
    "exercise",
    "fitness"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.9",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-fileupload": "^1.5.1",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-fileupload": "^1.5.1",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
